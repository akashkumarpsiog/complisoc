# Complisoc AI provider keys (replace values with your real keys; .env is git-ignored)
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# SonarQube scanner (reads security issues from a configured SonarQube project)
# See docs/SONARQUBE.md for setup (AWS EC2 or SonarCloud).
SONAR_HOST_URL=http://localhost:9000
SONAR_TOKEN=your_sonar_token_here

# Optional model overrides
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.3-70b-versatile
